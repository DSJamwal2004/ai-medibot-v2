# ── AI MediBot v2.2 — Environment Configuration ───────────────────────────────
# Copy this file to .env and fill in your values.
# cp .env.example .env

# ── Security (REQUIRED) ───────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=5df6a09d5ef93d1bafee640a952d941a8e39a3212d430221136ca24b29374ca4

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: openai | huggingface | anthropic | offline
# "offline" works without any API key — uses deterministic fallbacks
LLM_PROVIDER=offline

# ── OpenAI (if LLM_PROVIDER=openai) ──────────────────────────────────────────
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
# Optional: for OpenAI-compatible endpoints (Ollama, Together, etc.)
# OPENAI_BASE_URL=http://localhost:11434/v1

# ── Hugging Face (if LLM_PROVIDER=huggingface) ────────────────────────────────
HF_API_TOKEN=
HF_MODEL=Qwen/Qwen2.5-7B-Instruct

# ── Anthropic (if LLM_PROVIDER=anthropic) ────────────────────────────────────
ANTHROPIC_API_KEY=
# LLM_MODEL=claude-haiku-4-5-20251001

# ── RAG Configuration ────────────────────────────────────────────────────────
ENABLE_RAG=true
RAG_TOP_K=4
RAG_MIN_SCORE=0.25

# ── App Settings ──────────────────────────────────────────────────────────────
ENVIRONMENT=local
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
